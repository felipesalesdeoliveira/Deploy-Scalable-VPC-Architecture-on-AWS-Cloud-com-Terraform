aws_region                 = "us-east-1"
project_name               = "scalable-vpc"
environment                = "dev"

admin_vpc_cidr             = "192.168.0.0/16"
app_vpc_cidr               = "172.32.0.0/16"

admin_public_subnet_cidrs  = ["192.168.1.0/24", "192.168.2.0/24"]
app_public_subnet_cidrs    = ["172.32.1.0/24", "172.32.2.0/24"]
app_private_subnet_cidrs   = ["172.32.11.0/24", "172.32.12.0/24"]

single_nat_gateway         = true

bastion_instance_type      = "t3.micro"
bastion_allowed_ssh_cidrs  = ["YOUR_PUBLIC_IP/32"]
bastion_key_name           = null

app_instance_type          = "t2.micro"
app_asg_min                = 2
app_asg_max                = 4
app_asg_desired            = 2

app_repo_url               = ""
app_repo_branch            = "main"

create_route53_record      = false
route53_zone_id            = null
route53_record_name        = null
